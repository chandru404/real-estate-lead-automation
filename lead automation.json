    {
      "parameters": {
        "jsCode": "// Get the raw text from OpenAI\nconst rawResponse = $input.item.json.text;\n\n// Parse the JSON string into an object\nlet qualification;\ntry {\n  qualification = JSON.parse(rawResponse);\n} catch (error) {\n  qualification = {\n    score: 25,\n    category: \"COLD\",\n    intent_type: \"unclear\",\n    key_insight: \"Parse error — manual review needed\",\n    recommended_action: \"Check lead manually\"\n  };\n}\n\n// Get lead data from the Set node\n// ↓ Change this name to match YOUR Set node's exact name on the canvas\nconst leadData = $('clean').item.json;\n\n// Return one merged object\nreturn {\n  lead_id:     leadData.lead_id,\n  timestamp:   leadData.timestamp,\n  full_name:   leadData.full_name,\n  phone:       leadData.phone,\n  email:       leadData.email,\n  source:      leadData.source,\n  project:     leadData.project,\n  budget:      leadData.budget,\n  bhk:         leadData.bhk,\n  timeline:    leadData.timeline,\n  message:     leadData.message,\n  ai_score:    qualification.score,\n  ai_category: qualification.category,\n  ai_intent:   qualification.intent_type,\n  ai_insight:  qualification.key_insight,\n  ai_action:   qualification.recommended_action\n};"
      },
